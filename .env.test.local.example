# Copy this file to .env.test.local and fill in a dedicated Nextcloud News test user.
# Do not use a personal account or main password. Use a Nextcloud app password.

NEXTNEWS_TEST_SERVER=https://example.com
NEXTNEWS_TEST_USERNAME=nextnews-test
NEXTNEWS_TEST_APP_PASSWORD=replace-with-app-password
NEXTNEWS_TEST_FEED_URL=https://xkcd.com/rss.xml

# Live tests are opt-in. Keep this unset or 0 unless you intentionally want
# tests to access feeds/articles on the configured test account.
NEXTNEWS_RUN_LIVE_TESTS=1
