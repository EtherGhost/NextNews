{
    "name": "nextnews.cloudsite",
    "description": "Native but simple Ubuntu Touch client for Nextcloud News.",
    "architecture": "$ENV{ARCH}",
    "title": "NextNews",
    "hooks": {
        "nextnews": {
            "accounts": "nextnews.accounts",
            "apparmor": "nextnews.apparmor",
            "content-hub": "nextnews-contenthub.json",
            "desktop": "nextnews.desktop"
        }
    },
    "version": "@NEXTNEWS_VERSION@",
    "maintainer": "Etherghost <noreply@cloudsite.se>",
    "framework": "$ENV{CLICK_FRAMEWORK}"
}
